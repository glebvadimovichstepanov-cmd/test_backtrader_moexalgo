```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
.env
.env.local
*.env.*

# Logs and temp files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/
.tox/

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg
```